APP_NAME=OmniAudit MCP
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080

DATABASE_URL=sqlite+pysqlite:///./omniaudit.db
REDIS_URL=redis://localhost:6379/0

OBJECT_STORE_ROOT=./data/objects
REPORTS_ROOT=./data/reports
SITELINT_ASYNC_MODE=false
OBJECT_STORE_BACKEND=local
OBJECT_STORE_BUCKET=omniaudit
OBJECT_STORE_PREFIX=omniaudit
S3_ENDPOINT_URL=http://minio:9000
S3_REGION_NAME=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

OPERATOR_NAME=local-operator
WRITE_CONFIRMATION_SECRET=change-me
WRITE_CONFIRMATION_TTL_SECONDS=600

# Comma-separated
REPO_WRITE_ALLOWLIST=Prekzursil/omniaudit-mcp,Prekzursil/AdrianaArt,Prekzursil/env-inspector,Prekzursil/SWFOC-Mod-Menu,Prekzursil/Reframe
URL_ALLOWLIST=
URL_DENYLIST=localhost,127.0.0.1,0.0.0.0

MCP_AUTH_MODE=none
MCP_API_KEY=

# GitHub auth mode: pat or app
GITHUB_AUTH_MODE=pat
GITHUB_PAT=

GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=

ENVELOPE_MASTER_KEY_FILE=./data/secrets/master.key
SCAN_RATE_LIMIT_PER_MINUTE=10
GITHUB_WRITE_RATE_LIMIT_PER_MINUTE=30
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_FORMAT=json
PROMETHEUS_ENABLED=true
